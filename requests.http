### ========================================
### Auth — ParkApp API
### ========================================
### Instrucciones:
### 1. Instalá la extensión "REST Client" en VS Code
### 2. Hacé click en "Send Request" arriba de cada bloque
### 3. Primero ejecutá el Login, copiá el token y pegalo en @token

@host = http://localhost:3000
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOjEsInJvbGUiOiJhZG1pbiIsImlhdCI6MTc4MjA2OTg3NywiZXhwIjoxNzgyMDk4Njc3fQ.lPhiFRnkyHweY4MIMJ5kIztfdSYnVHuDvJbWugAbB18

### -----------------------------------------
### 1. Login (admin)
### -----------------------------------------

POST {{host}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

### -----------------------------------------
### 2. Login — password incorrecto (401)
### -----------------------------------------

POST {{host}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "incorrecta"
}

### -----------------------------------------
### 3. Login — campos vacíos (400)
### -----------------------------------------

POST {{host}}/auth/login
Content-Type: application/json

{
}

### -----------------------------------------
### 4. Register — sin token (401)
### -----------------------------------------

POST {{host}}/auth/register
Content-Type: application/json

{
  "username": "operador1",
  "password": "op123"
}

### -----------------------------------------
### 5. Register — con token admin (201)
### -----------------------------------------

POST {{host}}/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "username": "operador1",
  "password": "op123"
}

### -----------------------------------------
### 6. Register — username duplicado (409)
### -----------------------------------------

POST {{host}}/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "username": "operador1",
  "password": "op123"
}

### -----------------------------------------
### 7. Register — role inválido (400)
### -----------------------------------------

POST {{host}}/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "username": "otro",
  "password": "123",
  "role": "superadmin"
}

### -----------------------------------------
### 8. Health check
### -----------------------------------------

GET {{host}}/health

### ========================================
### Vehicles — ParkApp API
### ========================================

### -----------------------------------------
### 9. Crear vehículo — carro (201)
### -----------------------------------------

POST {{host}}/vehicles
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plate": "ABC123",
  "type": "carro"
}

### -----------------------------------------
### 10. Crear vehículo — moto (201)
### -----------------------------------------

POST {{host}}/vehicles
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plate": "DEF456",
  "type": "moto"
}

### -----------------------------------------
### 11. Crear vehículo — bicicleta (201)
### -----------------------------------------

POST {{host}}/vehicles
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plate": "BIC001",
  "type": "bicicleta"
}

### -----------------------------------------
### 12. Crear vehículo — placa duplicada (409)
### -----------------------------------------

POST {{host}}/vehicles
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plate": "ABC123",
  "type": "moto"
}

### -----------------------------------------
### 13. Crear vehículo — tipo inválido (400)
### -----------------------------------------

POST {{host}}/vehicles
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "plate": "XYZ999",
  "type": "camion"
}

### -----------------------------------------
### 14. Crear vehículo — sin token (401)
### -----------------------------------------

POST {{host}}/vehicles
Content-Type: application/json

{
  "plate": "SIN001",
  "type": "carro"
}

### -----------------------------------------
### 15. Listar vehículos (200)
### -----------------------------------------

GET {{host}}/vehicles
Authorization: Bearer {{token}}

### -----------------------------------------
### 16. Detalle vehículo por ID (200)
### -----------------------------------------

GET {{host}}/vehicles/1
Authorization: Bearer {{token}}

### -----------------------------------------
### 17. Vehículo no encontrado (404)
### -----------------------------------------

GET {{host}}/vehicles/9999
Authorization: Bearer {{token}}

### ========================================
### Spaces — ParkApp API
### ========================================

### -----------------------------------------
### 18. Listar espacios (200)
### -----------------------------------------

GET {{host}}/spaces
Authorization: Bearer {{token}}

### -----------------------------------------
### 19. PATCH espacio — marcar ocupado con vehículo (200, solo admin)
### -----------------------------------------

PATCH {{host}}/spaces/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "ocupado",
  "current_vehicle_id": 1
}

### -----------------------------------------
### 20. PATCH espacio — liberar espacio (200, solo admin)
### -----------------------------------------

PATCH {{host}}/spaces/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "libre"
}

### -----------------------------------------
### 21. PATCH espacio — status inválido (400)
### -----------------------------------------

PATCH {{host}}/spaces/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "reservado"
}

### -----------------------------------------
### 22. PATCH espacio — sin campos (400)
### -----------------------------------------

PATCH {{host}}/spaces/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
}

### -----------------------------------------
### 23. PATCH espacio — espacio inexistente (404)
### -----------------------------------------

PATCH {{host}}/spaces/9999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "libre"
}

### -----------------------------------------
### 24. PATCH espacio — vehículo inexistente (404)
### -----------------------------------------

PATCH {{host}}/spaces/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "current_vehicle_id": 9999
}

### ========================================
### Tariffs — ParkApp API
### ========================================

### -----------------------------------------
### 25. Listar tarifas (200)
### -----------------------------------------

GET {{host}}/tariffs
Authorization: Bearer {{token}}

### -----------------------------------------
### 26. PATCH tarifa — cambiar precio carro (200, solo admin)
### -----------------------------------------

PATCH {{host}}/tariffs/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "rate_per_block": 2500
}

### -----------------------------------------
### 27. PATCH tarifa — cambiar bloque a 20 min (200)
### -----------------------------------------

PATCH {{host}}/tariffs/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "block_minutes": 20
}

### -----------------------------------------
### 28. PATCH tarifa — sin campos (400)
### -----------------------------------------

PATCH {{host}}/tariffs/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
}

### -----------------------------------------
### 29. PATCH tarifa — precio negativo (400)
### -----------------------------------------

PATCH {{host}}/tariffs/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "rate_per_block": -500
}

### -----------------------------------------
### 30. PATCH tarifa — tarifa inexistente (404)
### -----------------------------------------

PATCH {{host}}/tariffs/9999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "rate_per_block": 3000
}
