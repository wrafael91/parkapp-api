generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────

enum Role {
  admin
  operador
}

enum VehicleType {
  carro
  moto
  bicicleta
}

enum SpaceStatus {
  libre
  ocupado
}

// ── Modelos ────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password_hash String
  role          Role     @default(operador)
  created_at    DateTime @default(now())

  @@map("users")
}

model Vehicle {
  id         Int         @id @default(autoincrement())
  plate      String      @unique
  type       VehicleType
  code       Int         @default(autoincrement())
  created_at DateTime    @default(now())

  parking_spaces  ParkingSpace[]
  parking_history ParkingHistory[]
  monthly_passes  MonthlyPass[]

  @@map("vehicles")
}

model ParkingSpace {
  id                 Int         @id @default(autoincrement())
  number             Int         @unique
  status             SpaceStatus @default(libre)
  current_vehicle_id Int?

  current_vehicle Vehicle? @relation(fields: [current_vehicle_id], references: [id])

  parking_history ParkingHistory[]

  @@map("parking_spaces")
}

model ParkingHistory {
  id             Int       @id @default(autoincrement())
  vehicle_id     Int
  space_id       Int
  entry_time     DateTime  @default(now())
  exit_time      DateTime?
  amount_charged Decimal?  @db.Decimal(10, 2)
  created_at     DateTime  @default(now())

  vehicle Vehicle      @relation(fields: [vehicle_id], references: [id])
  space   ParkingSpace @relation(fields: [space_id], references: [id])

  @@map("parking_history")
}

model MonthlyPass {
  id         Int      @id @default(autoincrement())
  vehicle_id Int
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  active     Boolean  @default(true)
  amount     Decimal  @db.Decimal(10, 2)

  vehicle Vehicle @relation(fields: [vehicle_id], references: [id])

  @@map("monthly_passes")
}

model Tariff {
  id            Int         @id @default(autoincrement())
  vehicle_type  VehicleType @unique
  rate_per_block Decimal    @db.Decimal(10, 2)
  block_minutes Int         @default(15)

  @@map("tariffs")
}

model Settings {
  id           Int    @id @default(1)
  total_spaces Int    @default(30)

  @@map("settings")
}
